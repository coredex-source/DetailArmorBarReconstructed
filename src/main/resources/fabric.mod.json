{
  "schemaVersion": 1,
  "id": "detailabreconst",
  "version": "${version}",
  "name": "Detail Armor Bar Reconstructed",
  "description": "Show more details of armors in Armor bar!",
  "authors": [
    "coredex-source"
  ],
  "orignal authors": [
    "RedLime"
  ],
  "contributors": [
    "RedLime - orignal author",
    "coredex-source - current maintainer",
    "snessim",
    "Heamaci",
    "ram6ert or rambert"
  ],
  "contact": {
    "sources": "https://github.com/coredex-source/DetailArmorBarReconstructed"
  },
  "license": "MIT",
  "icon": "assets/detailab/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "default",
        "value": "com.redlimerl.detailab.DetailArmorBar"
      }
    ],
    "modmenu": [
      "com.redlimerl.detailab.config.ModMenuConfigImpl"
    ]
  },
  "mixins": [
    "detailab.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.11.6",
    "fabric": "*",
    "minecraft": "1.21.6",
    "java": ">=17"
  }
}
