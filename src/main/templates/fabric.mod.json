{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "coredex-source"
  ],
  "contributors": [
    "RedLime - orignal author",
    "coredex-source - current maintainer",
    "snessim",
    "Heamaci",
    "ram6ert or rambert"
  ],
  "contact": {
    "sources": "${mod_sources}"
  },
  "license": "${mod_license}",
  "icon": "${mod_icon}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.redlimerl.detailab.loaders.fabric.DetailArmorBarFabric"
    ],
    "modmenu": [
      "com.redlimerl.detailab.config.ModMenuConfigImpl"
    ]
  },
  "mixins": [
    "detailab.mixins.json",
    "detailab.overflowingbars.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "fabric-api": "*",
    "java": ">=25",
    "minecraft": "${minecraft_dependency}",
    "eclipseui": "*"
  },
  "suggests": {
    "modmenu": "*",
    "detailab-compat": "*"
  }
}
